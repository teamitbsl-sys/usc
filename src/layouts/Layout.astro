---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'The finest luxury summer chalets in the Alps. Handpicked properties in Austria, Switzerland, and Italy from the team behind Ultimate Luxury Chalets.', image } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://ultimatesummerchalets.com');
---
<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Ultimate Summer Chalets</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:title" content={`${title} | Ultimate Summer Chalets`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white font-sans text-gray-800 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
