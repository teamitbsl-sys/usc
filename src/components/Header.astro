---
const navResorts = [
  {
    country: 'Austria',
    resorts: [
      { name: 'Kitzbuhel', href: '/resorts/austria/kitzbuhel' },
      { name: 'Lech', href: '/resorts/austria/lech' },
    ],
  },
  {
    country: 'Switzerland',
    resorts: [
      { name: 'Verbier', href: '/resorts/switzerland/verbier' },
      { name: 'Zermatt', href: '/resorts/switzerland/zermatt' },
      { name: 'Crans Montana', href: '/resorts/switzerland/crans-montana' },
      { name: 'Gstaad', href: '/resorts/switzerland/gstaad' },
    ],
  },
  {
    country: 'Italy',
    resorts: [
      { name: 'Cervinia', href: '/resorts/italy/cervinia' },
    ],
  },
];

const chaletCategories = [
  { name: 'All Summer Chalets', href: '/summer-chalets' },
  { name: 'Chalets with Private Pool', href: '/summer-chalets/with-pool' },
  { name: 'Catered Summer Chalets', href: '/summer-chalets/catered' },
  { name: 'Self-Catered Summer Chalets', href: '/summer-chalets/self-catered' },
  { name: 'Chalets with Hot Tub', href: '/summer-chalets/with-hot-tub' },
  { name: 'Chalets with Gym', href: '/summer-chalets/with-gym' },
  { name: 'Chalets with Sauna', href: '/summer-chalets/with-sauna' },
  { name: 'Chalets with Cinema', href: '/summer-chalets/with-cinema' },
];
---

<header class="bg-navy-dark text-white sticky top-0 z-50 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0 group flex items-center gap-3">
        <img src="/logo.svg" alt="" aria-hidden="true" class="h-9 w-9 flex-shrink-0" />
        <div class="flex flex-col leading-none">
          <span class="font-serif text-lg lg:text-xl font-semibold tracking-wide text-white group-hover:text-gold-light transition-colors duration-200">Ultimate Summer Chalets</span>
          <span class="gold-shimmer text-xs tracking-widest uppercase font-sans font-light">The Finest in the Alps</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center space-x-1">

        <!-- Resorts Dropdown -->
        <div class="relative group">
          <button class="nav-link flex items-center gap-1">
            Resorts
            <svg class="w-3.5 h-3.5 opacity-70 group-hover:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-0 w-64 bg-navy-dark border-t-2 border-gold opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-xl z-50">
            {navResorts.map(group => (
              <div class="py-3 px-4 border-b border-navy-light last:border-0">
                <p class="text-gold text-xs font-sans font-semibold tracking-widest uppercase mb-2">{group.country}</p>
                {group.resorts.map(resort => (
                  <a href={resort.href} class="block py-1.5 text-sm text-gray-300 hover:text-gold transition-colors duration-150">{resort.name}</a>
                ))}
              </div>
            ))}
          </div>
        </div>

        <!-- Summer Chalets Dropdown -->
        <div class="relative group">
          <button class="nav-link flex items-center gap-1">
            Summer Chalets
            <svg class="w-3.5 h-3.5 opacity-70 group-hover:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-0 w-64 bg-navy-dark border-t-2 border-gold opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-xl z-50">
            <div class="py-3 px-4">
              {chaletCategories.map(cat => (
                <a href={cat.href} class="block py-1.5 text-sm text-gray-300 hover:text-gold transition-colors duration-150">{cat.name}</a>
              ))}
            </div>
          </div>
        </div>

        <a href="/about" class="nav-link">About Us</a>
        <a href="/contact" class="nav-link">Contact</a>
      </nav>

      <!-- Phone + CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="tel:+441202203659" class="text-sm text-gray-300 hover:text-gold transition-colors duration-150 flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          +44 (0)1202 203659
        </a>
        <a href="/contact" class="btn-gold text-sm">Enquire Now</a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded text-gray-300 hover:text-white" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-navy border-t border-navy-light">
    <div class="px-4 py-4 space-y-1">
      <p class="text-gold text-xs font-semibold tracking-widest uppercase py-2">Resorts</p>
      {navResorts.map(group => (
        <div class="mb-3">
          <p class="text-gray-400 text-xs uppercase tracking-wider mb-1">{group.country}</p>
          {group.resorts.map(resort => (
            <a href={resort.href} class="block py-1.5 pl-3 text-sm text-gray-300 hover:text-gold">{resort.name}</a>
          ))}
        </div>
      ))}
      <div class="border-t border-navy-light pt-3 mt-3 space-y-1">
        <p class="text-gold text-xs font-semibold tracking-widest uppercase py-2">Summer Chalets</p>
        {chaletCategories.map(cat => (
          <a href={cat.href} class="block py-1.5 text-sm text-gray-300 hover:text-gold">{cat.name}</a>
        ))}
      </div>
      <div class="border-t border-navy-light pt-3 mt-3 space-y-2">
        <a href="/about" class="block py-1.5 text-sm text-gray-300 hover:text-gold">About Us</a>
        <a href="/contact" class="block py-1.5 text-sm text-gray-300 hover:text-gold">Contact</a>
        <a href="tel:+441202203659" class="block py-1.5 text-sm text-gray-300 hover:text-gold">+44 (0)1202 203659</a>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    @apply px-3 py-2 text-sm text-gray-300 hover:text-gold transition-colors duration-150 font-sans;
  }
  .btn-gold {
    @apply text-white font-sans font-medium px-5 py-2 transition-all duration-200;
    background: linear-gradient(135deg, #E5C85A 0%, #D4AF37 20%, #9B7D1A 50%, #D4AF37 80%, #E5C85A 100%);
  }
  .btn-gold:hover {
    background: linear-gradient(135deg, #F5E8A0 0%, #E5C850 20%, #B89022 50%, #E5C850 80%, #F5E8A0 100%);
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
