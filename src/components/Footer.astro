---
---
<footer class="bg-navy-dark text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <div class="flex flex-col leading-none">
            <span class="font-serif text-xl font-semibold text-white">Ultimate Summer Chalets</span>
            <span class="text-gold text-xs tracking-widest uppercase font-light mt-0.5">The Finest in the Alps</span>
          </div>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-5">
          A curated collection of the finest luxury summer chalets in the Alps, selected from the portfolios of Ultimate Luxury Chalets and Alps In Luxury.
        </p>
        <p class="text-xs text-gray-500">Part of Blue Skies Lifestyle Ltd</p>
        <div class="flex gap-4 mt-5">
          <a href="https://www.instagram.com/alpsinluxury" class="text-gray-500 hover:text-gold transition-colors" aria-label="Instagram">
