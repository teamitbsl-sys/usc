      <!-- Resorts -->
      <div>
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase mb-5 pb-2 border-b border-navy-light">Resorts</h3>
        <div class="space-y-1">
          <p class="text-gold text-xs uppercase tracking-wider mt-3 mb-1">Austria</p>
          <a href="/resorts/austria/kitzbuhel" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Kitzbuhel</a>
          <a href="/resorts/austria/lech" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Lech</a>
          <p class="text-gold text-xs uppercase tracking-wider mt-3 mb-1">Switzerland</p>
          <a href="/resorts/switzerland/verbier" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Verbier</a>
          <a href="/resorts/switzerland/zermatt" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Zermatt</a>
          <a href="/resorts/switzerland/crans-montana" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Crans Montana</a>
          <a href="/resorts/switzerland/gstaad" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Gstaad</a>
          <p class="text-gold text-xs uppercase tracking-wider mt-3 mb-1">Italy</p>
          <a href="/resorts/italy/cervinia" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Cervinia</a>
        </div>
      </div>

      <!-- Chalet Types -->
      <div>
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase mb-5 pb-2 border-b border-navy-light">Summer Chalets</h3>
        <div class="space-y-1">
          <a href="/summer-chalets" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">All Summer Chalets</a>
          <a href="/summer-chalets/with-pool" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Chalets with Private Pool</a>
          <a href="/summer-chalets/catered" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Catered Summer Chalets</a>
          <a href="/summer-chalets/self-catered" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Self-Catered Summer Chalets</a>
          <a href="/summer-chalets/with-hot-tub" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Chalets with Hot Tub</a>
          <a href="/summer-chalets/with-gym" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Chalets with Gym</a>
          <a href="/summer-chalets/with-sauna" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Chalets with Sauna</a>
          <a href="/summer-chalets/with-cinema" class="block text-sm text-gray-400 hover:text-gold py-0.5 transition-colors">Chalets with Cinema</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase mb-5 pb-2 border-b border-navy-light">Contact Us</h3>
        <div class="space-y-3 text-sm text-gray-400">
          <p>Our team of Alpine specialists are on hand to help you find the perfect summer chalet.</p>
          <div>
            <a href="tel:+441202203659" class="flex items-center gap-2 hover:text-gold transition-colors py-1">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              +44 (0)1202 203659
            </a>
            <a href="mailto:ask@ultimatesummerchalets.com" class="flex items-center gap-2 hover:text-gold transition-colors py-1">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              ask@ultimatesummerchalets.com
            </a>
          </div>
          <div class="text-xs text-gray-500 pt-2">
            <p>Mon-Thu 09:00-17:30</p>
            <p>Fri-Sun 09:00-17:00</p>
          </div>
          <a href="/contact" class="inline-block mt-3 bg-gold hover:bg-gold-light text-white text-sm font-medium px-5 py-2 transition-colors duration-200">Make an Enquiry</a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-navy-light pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-xs text-gray-500">
      <p>&copy; {new Date().getFullYear()} Ultimate Summer Chalets. Part of <a href="https://www.blueskieslifestyle.com" class="hover:text-gold transition-colors">Blue Skies Lifestyle Ltd</a>. Registered in England and Wales.</p>
      <div class="flex gap-5">
        <a href="/privacy-policy" class="hover:text-gold transition-colors">Privacy Policy</a>
        <a href="/terms-and-conditions" class="hover:text-gold transition-colors">Terms &amp; Conditions</a>
        <a href="/about" class="hover:text-gold transition-colors">About Us</a>
      </div>
    </div>
  </div>
</footer>
