---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Enquiry Received">
  <div class="min-h-[60vh] flex items-center justify-center px-4 py-20">
    <div class="max-w-lg text-center">
      <div class="w-16 h-16 bg-gold/10 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-serif text-3xl text-navy mb-4">Enquiry Received</h1>
      <p class="text-gray-600 leading-relaxed mb-8">Thank you for getting in touch. A member of our team will respond to your enquiry within one working day. If your enquiry is urgent, please call us directly on <a href="tel:+441202203659" class="text-gold hover:underline">+44 (0)1202 203659</a>.</p>
      <a href="/" class="inline-block bg-navy hover:bg-navy-light text-white font-sans font-medium px-8 py-3 transition-colors duration-200">Return to Homepage</a>
    </div>
  </div>
</Layout>
