---
import Layout from '../layouts/Layout.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
---

<Layout title="Contact Us" description="Speak to our team of Alpine specialists about luxury summer chalets in Austria, Switzerland, and Italy.">

  <div class="bg-navy-dark py-16 px-4 sm:px-6 text-center">
    <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3">Get in Touch</p>
    <h1 class="font-serif text-4xl sm:text-5xl text-white mb-4">Contact Us</h1>
    <p class="text-gray-300 max-w-xl mx-auto">Our Alpine specialists are on hand to help you find the perfect summer chalet. We respond to all enquiries within one working day.</p>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <div>
        <h2 class="font-serif text-2xl text-navy mb-6">How Can We Help?</h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          Whether you know exactly which chalet you would like, or you are simply looking for guidance on the best resort for your summer, our team is here to help. We have personal knowledge of every property and resort in our collection, and take great care to match each guest with the right chalet for them.
        </p>

        <div class="space-y-5 mb-10">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-cream flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="font-sans font-semibold text-navy mb-0.5">Telephone</p>
              <a href="tel:+441202203659" class="text-gray-600 hover:text-gold transition-colors">+44 (0)1202 203659</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-cream flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="font-sans font-semibold text-navy mb-0.5">Email</p>
              <a href="mailto:ask@ultimatesummerchalets.com" class="text-gray-600 hover:text-gold transition-colors">ask@ultimatesummerchalets.com</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-cream flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <p class="font-sans font-semibold text-navy mb-0.5">Address</p>
              <p class="text-gray-600">170 Charminster Road<br />Bournemouth, BH8 9RL<br />United Kingdom</p>
            </div>
          </div>
        </div>

        <div class="bg-cream p-6">
          <h3 class="font-serif text-lg text-navy mb-3">Office Hours</h3>
          <div class="space-y-1 text-sm text-gray-600">
            <div class="flex justify-between"><span>Monday to Thursday</span><span class="font-medium">09:00 to 17:30</span></div>
            <div class="flex justify-between"><span>Friday</span><span class="font-medium">09:00 to 17:00</span></div>
            <div class="flex justify-between"><span>Saturday to Sunday</span><span class="font-medium">09:00 to 17:00</span></div>
          </div>
        </div>
      </div>

      <div>
        <EnquiryForm />
      </div>

    </div>
  </div>
</Layout>
