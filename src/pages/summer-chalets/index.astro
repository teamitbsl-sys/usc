---
import Layout from '../../layouts/Layout.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { chalets } from '../../data/chalets';
---

<Layout title="Luxury Summer Chalets in the Alps" description="Browse our full collection of the finest luxury summer chalets in Austria, Switzerland, and Italy.">

  <!-- Page Header -->
  <div class="bg-navy-dark py-16 px-4 sm:px-6 text-center">
    <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3">Our Collection</p>
    <h1 class="font-serif text-4xl sm:text-5xl text-white mb-4">Luxury Summer Chalets</h1>
    <p class="text-gray-300 max-w-2xl mx-auto leading-relaxed">
      {chalets.length} exceptional properties across Austria, Switzerland, and Italy, each hand-selected for its quality, facilities, and Alpine setting.
    </p>
  </div>

  <!-- Filters -->
  <div class="bg-cream border-b border-gray-200 sticky top-16 lg:top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex flex-wrap gap-3 items-center">
      <span class="text-xs font-semibold text-navy tracking-wider uppercase">Filter:</span>
      <a href="/summer-chalets" class="filter-tag filter-tag-active">All</a>
      <a href="/summer-chalets/catered" class="filter-tag">Catered</a>
      <a href="/summer-chalets/self-catered" class="filter-tag">Self-Catered</a>
      <a href="/summer-chalets/with-pool" class="filter-tag">Pool</a>
      <a href="/summer-chalets/with-hot-tub" class="filter-tag">Hot Tub</a>
      <a href="/summer-chalets/with-gym" class="filter-tag">Gym</a>
      <a href="/summer-chalets/with-sauna" class="filter-tag">Sauna</a>
      <a href="/summer-chalets/with-cinema" class="filter-tag">Cinema</a>
    </div>
  </div>

  <!-- Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {chalets.map(chalet => <PropertyCard chalet={chalet} />)}
    </div>
  </section>

</Layout>

<style>
  .filter-tag {
    @apply text-xs font-sans px-3 py-1.5 border border-gray-300 text-gray-600 hover:border-navy hover:text-navy transition-colors duration-150;
  }
  .filter-tag-active {
    @apply bg-navy text-white border-navy;
  }
</style>
