---
import Layout from '../../layouts/Layout.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { chalets, getChaletsByAmenity } from '../../data/chalets';

export function getStaticPaths() {
  return [
    { params: { filter: 'catered' }, props: { label: 'Catered Summer Chalets', amenity: null, board: 'Catered' } },
    { params: { filter: 'self-catered' }, props: { label: 'Self-Catered Summer Chalets', amenity: null, board: 'Self-Catered' } },
    { params: { filter: 'with-pool' }, props: { label: 'Summer Chalets with Private Pool', amenity: 'Pool', board: null } },
    { params: { filter: 'with-hot-tub' }, props: { label: 'Summer Chalets with Hot Tub', amenity: 'Hot Tub', board: null } },
    { params: { filter: 'with-gym' }, props: { label: 'Summer Chalets with Gym', amenity: 'Gym', board: null } },
    { params: { filter: 'with-sauna' }, props: { label: 'Summer Chalets with Sauna', amenity: 'Sauna', board: null } },
    { params: { filter: 'with-cinema' }, props: { label: 'Summer Chalets with Cinema', amenity: 'Cinema', board: null } },
  ];
}

const { filter } = Astro.params;
const { label, amenity, board } = Astro.props;

let filtered = chalets;
if (amenity) filtered = getChaletsByAmenity(amenity);
if (board) filtered = filtered.filter(c => c.boardBasis.some(b => b === board));
---

<Layout title={label}>
  <div class="bg-navy-dark py-16 px-4 sm:px-6 text-center">
    <p class="text-gold text-xs font-semibold tracking-widest uppercase mb-3">Our Collection</p>
    <h1 class="font-serif text-4xl sm:text-5xl text-white mb-4">{label}</h1>
    <p class="text-gray-300">{filtered.length} {filtered.length === 1 ? 'property' : 'properties'} found</p>
  </div>

  <div class="bg-cream border-b border-gray-200 sticky top-16 lg:top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex flex-wrap gap-3 items-center">
      <span class="text-xs font-semibold text-navy tracking-wider uppercase">Filter:</span>
      <a href="/summer-chalets" class="filter-tag">All</a>
      <a href="/summer-chalets/catered" class={`filter-tag ${filter === 'catered' ? 'filter-tag-active' : ''}`}>Catered</a>
      <a href="/summer-chalets/self-catered" class={`filter-tag ${filter === 'self-catered' ? 'filter-tag-active' : ''}`}>Self-Catered</a>
      <a href="/summer-chalets/with-pool" class={`filter-tag ${filter === 'with-pool' ? 'filter-tag-active' : ''}`}>Pool</a>
      <a href="/summer-chalets/with-hot-tub" class={`filter-tag ${filter === 'with-hot-tub' ? 'filter-tag-active' : ''}`}>Hot Tub</a>
      <a href="/summer-chalets/with-gym" class={`filter-tag ${filter === 'with-gym' ? 'filter-tag-active' : ''}`}>Gym</a>
      <a href="/summer-chalets/with-sauna" class={`filter-tag ${filter === 'with-sauna' ? 'filter-tag-active' : ''}`}>Sauna</a>
      <a href="/summer-chalets/with-cinema" class={`filter-tag ${filter === 'with-cinema' ? 'filter-tag-active' : ''}`}>Cinema</a>
    </div>
  </div>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    {filtered.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {filtered.map(chalet => <PropertyCard chalet={chalet} />)}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-400 font-serif text-xl mb-4">No chalets found for this filter.</p>
        <a href="/summer-chalets" class="text-gold hover:underline">View all chalets</a>
      </div>
    )}
  </section>
</Layout>

<style>
  .filter-tag { @apply text-xs font-sans px-3 py-1.5 border border-gray-300 text-gray-600 hover:border-navy hover:text-navy transition-colors duration-150; }
  .filter-tag-active { @apply bg-navy text-white border-navy; }
</style>
